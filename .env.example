# CarePath — Environment Variables
# Copy this to .env.local and fill in your keys.
# NEVER commit .env.local to git.

# xAI API key — get from console.x.ai
# Used server-side only: /app/api/realtime-token/route.ts
XAI_API_KEY=

# OpenAI API key — get from platform.openai.com
# Used server-side only: /app/api/classify/route.ts
OPENAI_API_KEY=
